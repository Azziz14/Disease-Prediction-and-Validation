# Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/?appName=DiseasePredictionValidation
MONGODB_DB_NAME=DiseasePredictionValidation

# AI/ML API Keys
OPENAI_API_KEY=your_openai_api_key_here
